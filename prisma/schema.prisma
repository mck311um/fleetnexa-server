datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RentalType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}


model Tenant {
  id          Int      @id @default(autoincrement())
  tenantCode  String   @unique 
  name        String
  email       String   @unique
  number      String   @unique
  setupComplete     Boolean
  minimumBooking Int
  rentalType  RentalType
  discounts   TenantDiscount[]
  paymentMethods PaymentMethod[]
  pickupLocations       PickupLocation[]
  dropoffLocations      DropoffLocation[]
  services Services[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]   
  vehicles    Vehicle[] @relation("TenantVehicles")
}

model TenantDiscount {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threshold        Int    
  percentage       Float    
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PaymentMethod {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  method           String 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PickupLocation {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String   
  address          String  
  latitude         Float
  longitude        Float
  price            Float

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DropoffLocation {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String   
  address          String 
  latitude         Float
  longitude        Float
  price            Float


  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Services {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String   
  description      String  
  price            Float
}


model User {
  id          Int      @id @default(autoincrement())
  password    String
  firstName     String
  lastName    String
  username    String  @unique

  tenantId    Int      
  tenant      Tenant   @relation(fields: [tenantId], references: [id]) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  make         String
  model        String
  year         Int
  color        String
  licensePlate String   @unique
  status       String   @default("available") 
  mileage      Int
  fuelType     String
  transmission String
  engineVolume Int
  wheelDrive   String
  pricePerDay  Float  

  tenantId    Int      
  tenant      Tenant   @relation("TenantVehicles", fields: [tenantId], references: [id]) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


}

model VehiclePart {
  id             Int      @id @default(autoincrement())
  partId         String
  partName       String
}